# ─── Firebase Web (client) config ────────────────────────────────────────────
# Safe to expose in the browser bundle (these are public by design).
# Leave blank to run in offline/seed-data mode (no Firebase required).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=radeon-arena.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=radeon-arena
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=radeon-arena.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin (server) credentials ─────────────────────────────────────
# Provide ONE of the following. If neither is set the server falls back to the
# bundled seed data so the site still renders end-to-end without a backend.
#   1) Path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
#   2) Or inline the service-account JSON (escaped) — handy for App Hosting
FIREBASE_SERVICE_ACCOUNT=

# ─── Leaderboard snapshot ────────────────────────────────────────────────────
# How often the /static/snapshot aggregate is regenerated (hours).
SNAPSHOT_INTERVAL_HOURS=0.5

# ─── Recipe generation (optional, powers POST /api/generate-recipe) ──────────
# OpenAI-compatible endpoint used to turn a raw command into a structured recipe.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
