# ─── Database ────────────────────────────────────────────────────────────────
# Postgres connection. Leave blank to run in offline mode (bundled JSON dataset).
DATABASE_URL=postgres://radeon:radeon_arena_pw@localhost:5432/radeon_arena
# Password for the bundled docker-compose Postgres container.
POSTGRES_PASSWORD=radeon_arena_pw

# ─── Auth (token-based, no external provider) ────────────────────────────────
# ADMIN_TOKEN  gates /admin + result verification.
# SUBMIT_TOKEN gates result submission + discussion comments.
ADMIN_TOKEN=
SUBMIT_TOKEN=

# ─── Verification runner (optional) ──────────────────────────────────────────
# If set, admin "verify" POSTs the recipe here to auto-rerun on a trusted card
# and compare with the self-reported value. Unset → admin verifies manually.
RUNNER_VERIFY_URL=
RUNNER_TOKEN=
VERIFY_TOLERANCE_PCT=5

# ─── Leaderboard snapshot ────────────────────────────────────────────────────
# How often the /static/snapshot aggregate is regenerated (hours).
SNAPSHOT_INTERVAL_HOURS=0.5

# ─── Recipe generation (optional, powers POST /api/generate-recipe) ──────────
# OpenAI-compatible endpoint used to turn a raw command into a structured recipe.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
