rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public leaderboard data is world-readable.
    match /benchmarks/{benchmarkId} {
      allow read: if true;

      // A signed-in user may submit their own benchmark.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Owners may edit their submission; admins may moderate anything.
      allow update, delete: if request.auth != null
                            && (resource.data.userId == request.auth.uid
                                || request.auth.token.admin == true);
    }

    // Everything else is locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
